# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Secrets (NEVER commit)
*.json.key
sa-key.json
*-credentials.json

# Logs
*.log
logs/

# PyInstaller
# 自動生成される *.spec は除外だが、プロジェクトで管理する spec は例外。
*.spec
!wiseman_hub.spec
!wiseman_launcher.spec

# uv
.python-version

# UI catalogs (environment-specific, may contain sensitive data)
data/ui_catalogs/*.json
data/ui_catalogs/*.txt
.envrc
.serena/
data/screenshots/

# PDF merge pipeline session files (contain OCR 氏名 / matched B/C paths)
# ADR-010 参照: .sessions/ 配下は個人情報を含むため誤コミット防止
**/.sessions/

# Claude Code runtime (scheduled_tasks.lock, transient state)
.claude/

# WisemanMock C# build artifacts (tests/integration helper)
mock_wiseman_app/WisemanMock/bin/
mock_wiseman_app/WisemanMock/obj/

# Diagnostic outputs (scripts/diagnose-tcl.ps1 + pytest retry verification)
diagnose-output.txt
pytest-retry-verify.txt

# Firebase Hosting local artifacts
.firebase/

# Playwright MCP local artifacts (screenshots / traces)
.playwright-mcp/

# Debug screenshots at repo root from ad-hoc Playwright runs
# （docs/help-site/assets/ 配下の正規スクショは除外しない）
/*.png

# Firebase / Firestore CLI debug logs (auto-generated)
firebase-debug.log
firestore-debug.log
