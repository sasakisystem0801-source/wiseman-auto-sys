# =========================================================================
# Wiseman Hub 検証専用 config テンプレート
# =========================================================================
#
# ■ 目的
#   PR5 ex_extractor Windows 実機検証 (AC-2〜AC-14) で本番 NAS
#   (`facility_root_dir`) や本番 ex_source_dir を汚さないための検証用 config。
#
# ■ 使い方（推奨手順）
#   1. 本ファイルを `%USERPROFILE%\wiseman-hub\config\test.toml` にコピー
#   2. 本番 config (`%USERPROFILE%\wiseman-hub\config\default.toml`) から
#      検証で値が必要な項目（exe_path / endpoint_url / api_key 等）を移植。
#      ※ 検証では Wiseman 起動・GCP 通信・OCR 通信は発生しないため、
#         空文字 / ダミー値でも fail しない
#   3. 下記の検証専用パスだけを実環境向けに編集
#      - [pdf_merge] facility_root_dir / ex_source_dir
#      - [pdf_merge.facility_aliases]
#   4. 検証実行時は WISEMAN_HUB_CONFIG 環境変数で本ファイルを参照させる
#      （詳細: docs/handoff/pr5-ex-extractor-runbook.md §2-2）
#
# ■ 重要: ショートカット起動の落とし穴
#   PowerShell で `$env:WISEMAN_HUB_CONFIG = "..."` を設定しても、
#   デスクトップショートカット経由で起動した exe はその環境変数を継承しない。
#   検証時は必ず PowerShell から `Start-Process -FilePath ...` で起動するか、
#   検証専用の .ps1 / .cmd ラッパーを経由すること（runbook §2-2 参照）。
#
# ■ 想定検証パス
#   facility_root_dir = "%USERPROFILE%\wiseman-test\facilities"
#   ex_source_dir     = "%USERPROFILE%\wiseman-test\ex_source"
#
#   検証用 .ex_ ファイルの fixture 要件は
#   docs/handoff/ex-test-fixtures.md を参照。
#
# =========================================================================

# ───────────────────────────────────────────────────────────────────────
# 検証で必要となる最小セクション（本番 config からコピー or ダミー値）
# ───────────────────────────────────────────────────────────────────────

[app]
version = "0.1.0"
log_level = "DEBUG"        # 検証時は詳細ログを推奨
log_dir = ""

[wiseman]
exe_path = ""              # 検証では Wiseman 起動なし → 空でも fail しない
startup_wait_sec = 15
window_title_pattern = ".*管理システム SP.*"

[[reports.targets]]
name = "ケア記録集計表"
menu_path = ["ケア記録", "集計表"]
output_format = "csv"

[gcp]
project_id = "wiseman-hub-prod"
bucket_name = "wiseman-hub-prod-datalake"
service_account_key_path = "config/sa-key.json"  # 検証では GCS 通信なし
region = "asia-northeast1"

[ocr_backend]
# 検証では OCR 通信は発生しない（ex_extractor は SFX 経由の PDF 抽出のみ）
endpoint_url = "https://example.invalid"
api_key = "dummy-not-used-in-ex-extractor-validation"
timeout_sec = 30
max_retries = 3

# ───────────────────────────────────────────────────────────────────────
# [pdf_merge] 検証用パス（■ 検証ごとに編集）
# ───────────────────────────────────────────────────────────────────────
[pdf_merge]
# PDF 結合は検証スコープ外（AC-2〜AC-14 は ex_extractor のみ）
input_dir = ""
output_dir = ""
source_a_filename = ""
source_d_filename = ""
source_b_pattern = "B_{name}.pdf"
source_c_pattern = "C_{name}.pdf"
concat_order = ["A", "B", "C"]

# ex_extractor 検証用パス（■ 必須編集）
# 本番 NAS (\\Tera-station\share\03.FAX(...)) を絶対に指さないこと。
ex_source_dir = "C:\\Users\\sasak\\wiseman-test\\ex_source"
facility_root_dir = "C:\\Users\\sasak\\wiseman-test\\facilities"

[pdf_merge.user_name_bbox]
x0 = 0.0
y0 = 0.0
x1 = 0.0
y1 = 0.0
dpi = 200

# ───────────────────────────────────────────────────────────────────────
# [pdf_merge.facility_aliases] AC-3 / AC-11 検証用 alias
# ───────────────────────────────────────────────────────────────────────
# canonical（key）は facility_root_dir 配下に実在するフォルダ名と完全一致が必要。
# 値は必ず list 型で書く（"abc" 単独は禁止 — 文字単位分解されるため TypeError）。
#
# 例: 検証用に 1-2 件の alias を登録。
[pdf_merge.facility_aliases]
"<検証用事業所A名>" = ["<短縮名 A1>", "<別表記 A1>"]
"<検証用事業所B名>" = ["<短縮名 B1>"]

# AC-11 (orphan_alias_canonicals banner 検証) で使う場合のみ追加。
# 下記 canonical は facility_root_dir に存在しない → orphan として警告される。
# 検証完了後は削除すること。
# "消えた施設" = ["短縮"]
