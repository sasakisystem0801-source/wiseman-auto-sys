# =========================================================================
# Wiseman Hub 設定テンプレート（施設別に編集）
# =========================================================================
#
# ■ 使い方（初回セットアップ）
#   1. このファイルを同じフォルダに `default.toml` という名前でコピー
#   2. メモ帳等で `default.toml` を開き、下記「■ 必須編集」セクションを施設ごとに編集
#   3. 文字コードは UTF-8（BOM なし）で保存
#   4. デスクトップの「Wiseman PDF ツール」を起動
#
#   起動後は本体の「設定」ボタンから GUI で編集できます（以降は手動編集不要）。
#
# ■ 必須編集セクション（施設別）
#   - [wiseman] exe_path                       : ワイズマンショートカットまたは exe のパス
#   - [gcp] service_account_key_path           : GCP サービスアカウントキーのパス（受領した sa-key.json の置き場所）
#   - [ocr_backend]                            : Cloud Run プロキシ情報（弊社から別途受領）
#   - [pdf_merge]                              : PDF 結合の入出力フォルダと施設別パラメータ
#
# ■ 更新時の注意
#   配布 ZIP を更新する際、`default.toml.sample` は上書き更新されますが、
#   施設側でコピーした `default.toml` は保持されます（既存設定の上書き防止）。
#   新しい設定項目が追加された場合は本ファイルを参考に `default.toml` へ手動で追記してください。
#
# =========================================================================

# -------------------------------------------------------------------------
# [app] アプリケーション全体設定（通常はそのまま）
# -------------------------------------------------------------------------
[app]
version = "0.1.0"
log_level = "INFO"         # "DEBUG" / "INFO" / "WARNING" / "ERROR"
log_dir = ""               # 空の場合はカレントディレクトリに出力

# -------------------------------------------------------------------------
# [wiseman] ワイズマン起動設定（■ 必須編集: exe_path）
# -------------------------------------------------------------------------
[wiseman]
# ワイズマンの起動方法（.lnk または .exe）を施設の環境に合わせて設定してください。
#
# 例 1: デスクトップ上のショートカット経由で起動（最も一般的）
#   exe_path = "C:\\Users\\<USER>\\OneDrive\\デスクトップ\\ワイズマンASPサービス起動_O.lnk"
#
# 例 2: .exe を直接起動
#   exe_path = "C:\\Program Files\\Wiseman\\wiseman.exe"
exe_path = ""              # ■ 必須: ショートカットまたは exe のフルパス
startup_wait_sec = 15      # 起動・USB ドングル認証の待機秒数（通常はそのまま）
window_title_pattern = ".*管理システム SP.*"

# 認証は USB ドングルのみ（アプリ内ログイン画面なし、ADR-007 参照）。
# 起動後は「ワイズマンシステムSP」ランチャーが開き、ケア記録システムへ自動遷移します。

# -------------------------------------------------------------------------
# [schedule] 定期実行（通常はそのまま / 自動起動したい場合のみ有効化）
# -------------------------------------------------------------------------
[schedule]
enabled = false
cron = "0 8 * * *"         # 毎日 8 時（cron 形式）

# -------------------------------------------------------------------------
# [[reports.targets]] 抽出対象の帳票（通常はそのまま）
# -------------------------------------------------------------------------
[[reports.targets]]
name = "ケア記録集計表"
menu_path = ["ケア記録", "集計表"]
output_format = "csv"

# -------------------------------------------------------------------------
# [gcp] GCP 接続設定（■ 必須編集: service_account_key_path）
# -------------------------------------------------------------------------
[gcp]
project_id = "wiseman-hub-prod"
bucket_name = "wiseman-hub-prod-datalake"
service_account_key_path = "config/sa-key.json"   # ■ 必須: 受領した sa-key.json の配置パス
region = "asia-northeast1"                         # 東京リージョン（APPI 準拠、ADR-003）

# -------------------------------------------------------------------------
# [updater] 自動更新（通常はそのまま）
# -------------------------------------------------------------------------
[updater]
enabled = false
check_interval_hours = 1
release_bucket = ""

# -------------------------------------------------------------------------
# [ocr_backend] Cloud Run OCR プロキシ（■ 必須編集）
# -------------------------------------------------------------------------
# PDF 分割・条件付き再結合機能で利用者名を OCR するための Cloud Run プロキシ設定。
# クライアントに GCP 認証情報を持たせず、Vertex AI Gemini 2.5 Flash を経由利用します（ADR-008）。
# endpoint_url と api_key は弊社から別途連絡します。
[ocr_backend]
endpoint_url = ""          # ■ 必須: 例 "https://wiseman-ocr-proxy-xxx-an.a.run.app"
api_key = ""               # ■ 必須: Secret Manager 発行のキー
timeout_sec = 30
max_retries = 3

# -------------------------------------------------------------------------
# [pdf_merge] PDF 分割・結合（■ 必須編集: input_dir / output_dir / user_name_bbox）
# -------------------------------------------------------------------------
# フォルダ構成と命名規則:
#   - input_dir     : A(複数利用者 PDF) / B・C(利用者別 PDF) / D(共通 PDF) を配置するフォルダ
#   - output_dir    : 結合済み PDF の出力先
#   - source_a_filename : 複数利用者をまとめた A の PDF ファイル名
#   - source_d_filename : 全利用者共通で末尾結合する D の PDF ファイル名
#   - source_b_pattern / source_c_pattern : 利用者名で展開される B/C のファイル名パターン
#                                            （`{name}` が OCR 抽出氏名に置換される）
#   - concat_order  : 利用者ごとの並び順（"A","B","C" の並び替え。"D" は必ず末尾）
[pdf_merge]
input_dir = ""             # ■ 必須: 例 "C:\\Users\\<USER>\\介護記録\\入力"
output_dir = ""            # ■ 必須: 例 "C:\\Users\\<USER>\\介護記録\\出力"
source_a_filename = ""     # ■ 必須: 例 "A_複数利用者.pdf"
source_d_filename = ""     # 空の場合 D は結合しない
source_b_pattern = "B_{name}.pdf"
source_c_pattern = "C_{name}.pdf"
concat_order = ["A", "B", "C"]

# A の各ページから利用者名を切り出す固定矩形（ポイント単位、■ 必須編集）。
# 施設ごとの帳票レイアウトに合わせて、A の氏名表示位置を指定してください。
# 単位: ポイント（1/72 インチ）。dpi は OCR 前処理用のレンダリング解像度。
[pdf_merge.user_name_bbox]
x0 = 0.0                   # ■ 必須: 切り出し矩形の左上 x 座標
y0 = 0.0                   # ■ 必須: 切り出し矩形の左上 y 座標
x1 = 0.0                   # ■ 必須: 切り出し矩形の右下 x 座標
y1 = 0.0                   # ■ 必須: 切り出し矩形の右下 y 座標
dpi = 200
